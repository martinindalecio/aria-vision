GOOGLE_API_KEY=your_key_here
# Global req/min cap kept safely below gemini-3.1-flash-lite's ~15 RPM free-tier limit.
# Raise only if you upgrade to a paid tier with a higher quota.
GEMINI_MAX_RPM=12

# Upstash Redis — auto-wired by the Upstash Marketplace integration
# Run: vercel env pull .env.local  (after integration is connected in the Vercel dashboard)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron auth — generate once: openssl rand -hex 32
# Add to Vercel: Settings → Environment Variables → Production + Development
CRON_SECRET=

# Day boundary for the daily blog (optional, defaults to Europe/Madrid)
LOG_TIMEZONE=Europe/Madrid
